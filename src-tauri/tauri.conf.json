{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Music Companion",
  "version": "1.0.1",
  "identifier": "com.musiccompanion.overlay",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Music Companion",
        "width": 520,
        "height": 720,
        "minWidth": 220,
        "minHeight": 110,
        "center": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "msi"],
    "icon": ["icons/icon.ico"],
    "publisher": "Music Companion",
    "category": "Music",
    "shortDescription": "Live lyrics overlay for Windows",
    "longDescription": "A transparent always-on-top lyrics overlay using Windows Media Transport Controls and LRCLIB.",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {}
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI0Qjc2MUUwMzA1OUY1QTgKUldTbzlWa3c0R0czSkJVNVZBeU5kYXhqbUwwWWNhdEtJNERWajgrbDBzeFFrSytwYVAzSHQwbDAK",
      "endpoints": [
        "https://github.com/JustMarkDev/music-companion/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
